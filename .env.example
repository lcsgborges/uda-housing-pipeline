APP_NAME=Pipeline UDA
APP_ENV=dev
DATABASE_URL=postgresql+asyncpg://uda:uda@localhost:5432/uda

API_PORT=8000
DOCS_PORT=8001
POSTGRES_PORT=5432
RUSTFS_API_PORT=9000
RUSTFS_CONSOLE_PORT=9001

POSTGRES_DB=uda
POSTGRES_USER=uda
POSTGRES_PASSWORD=uda
DOCUMENTS_DIR=./data/documents
LOG_LEVEL=INFO
STORAGE_BACKEND=rustfs
RUSTFS_ENDPOINT=localhost:9000
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin
RUSTFS_BUCKET=uda-documents
RUSTFS_SECURE=false

LLM_PROVIDER=ollama
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
EXTRACTION_PROMPT_VERSION=v2
EXTRACTION_BATCH_SIZE=5

REQUEST_TIMEOUT_SECONDS=20
USER_AGENT=Pipeline-UDA/1.0
ENABLE_INGESTION_SCHEDULER=false
INGESTION_SCHEDULE_HOUR=2
INGESTION_SCHEDULE_MINUTE=0
SCHEDULER_TIMEZONE=America/Sao_Paulo
EXTRACTION_FULL_SCAN_MAX_CHARS=14000
EXTRACTION_CONTEXT_MAX_CHARS=18000
