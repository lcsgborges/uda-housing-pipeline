APP_NAME=Pipeline UDA
APP_ENV=dev
DATABASE_URL=postgresql+asyncpg://uda:uda@localhost:5432/uda
POSTGRES_DB=uda
POSTGRES_USER=uda
POSTGRES_PASSWORD=uda
DOCUMENTS_DIR=./data/documents
LOG_LEVEL=INFO
STORAGE_BACKEND=rustfs
RUSTFS_ENDPOINT=localhost:9000
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin
RUSTFS_BUCKET=uda-documents
RUSTFS_SECURE=false

LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
EXTRACTION_PROMPT_VERSION=v2
EXTRACTION_BATCH_SIZE=5

REQUEST_TIMEOUT_SECONDS=20
USER_AGENT=Pipeline-UDA/1.0
ENABLE_INGESTION_SCHEDULER=false
INGESTION_POLL_INTERVAL_MINUTES=1440
EXTRACTION_FULL_SCAN_MAX_CHARS=14000
EXTRACTION_CONTEXT_MAX_CHARS=18000
